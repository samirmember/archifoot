{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content_title %}Tableau de bord{% endblock %}

{% block main %}
    <section class="admin-dashboard">
        <div class="admin-dashboard__hero">
            <div>
                <p class="admin-dashboard__eyebrow">Vue d’ensemble</p>
                <h1 class="admin-dashboard__title">Console Archifoot</h1>
                <p class="admin-dashboard__subtitle">
                    Centralisez vos opérations, surveillez les données clés et pilotez l’activité en temps réel.
                </p>
            </div>
            <div class="admin-dashboard__hero-card">
                <span class="admin-dashboard__hero-label">État</span>
                <strong>Synchronisation active</strong>
                <p>Données match et saisons prêtes à être enrichies.</p>
            </div>
        </div>

        <div class="admin-dashboard__grid">
            <article class="admin-dashboard__card">
                <h3>Gestion des compétitions</h3>
                <p>Suivez les éditions, phases et classements avec un accès rapide aux entités clés.</p>
                <span class="admin-dashboard__chip">Compétitions</span>
            </article>
            <article class="admin-dashboard__card">
                <h3>Suivi des matchs</h3>
                <p>Consultez les feuilles de match, cartons, buts et compositions en un seul endroit.</p>
                <span class="admin-dashboard__chip">Rencontres</span>
            </article>
            <article class="admin-dashboard__card">
                <h3>Base de données joueurs</h3>
                <p>Regroupez les joueurs, historiques de clubs et stats de sélection.</p>
                <span class="admin-dashboard__chip">Joueurs</span>
            </article>
        </div>
    </section>
{% endblock %}
