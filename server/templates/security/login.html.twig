{% extends 'base.html.twig' %}

{% block title %}Log in{% endblock %}

{% block stylesheets %}
    <style>
        :root {
            color-scheme: light;
            --bg: #0b1023;
            --card: rgba(255, 255, 255, 0.08);
            --card-strong: rgba(255, 255, 255, 0.16);
            --text: #f7f8ff;
            --muted: rgba(255, 255, 255, 0.7);
            --accent: #7c5cff;
            --accent-strong: #6a4bff;
            --danger: #ff5f6d;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            font-family: "Inter", "Segoe UI", system-ui, -apple-system, sans-serif;
            background: radial-gradient(circle at top, #1f2866 0%, #0b1023 48%, #070912 100%);
            color: var(--text);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 32px 16px;
        }

        .login-shell {
            width: min(1100px, 100%);
            display: grid;
            gap: 32px;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            align-items: stretch;
        }

        .login-info {
            background: linear-gradient(135deg, rgba(124, 92, 255, 0.35), rgba(43, 58, 140, 0.6));
            border-radius: 32px;
            padding: 48px;
            position: relative;
            overflow: hidden;
            box-shadow: 0 30px 90px rgba(7, 9, 18, 0.6);
        }

        .login-info::after {
            content: "";
            position: absolute;
            inset: -20% 10% auto auto;
            width: 260px;
            height: 260px;
            background: radial-gradient(circle, rgba(255, 255, 255, 0.3), transparent 70%);
            opacity: 0.5;
        }

        .login-info h1 {
            font-size: clamp(2rem, 2.5vw, 2.75rem);
            margin: 0 0 16px;
            letter-spacing: 0.3px;
        }

        .login-info p {
            margin: 0 0 32px;
            color: var(--muted);
            line-height: 1.6;
        }

        .info-pills {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
        }

        .info-pill {
            padding: 10px 16px;
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.2);
            font-size: 0.9rem;
            color: #f5f4ff;
            backdrop-filter: blur(8px);
        }

        .login-card {
            background: var(--card);
            border-radius: 28px;
            padding: 40px;
            border: 1px solid rgba(255, 255, 255, 0.12);
            box-shadow: 0 25px 70px rgba(7, 9, 18, 0.55);
            backdrop-filter: blur(16px);
        }

        .login-card h2 {
            margin: 0 0 8px;
            font-size: 1.9rem;
        }

        .login-card span {
            color: var(--muted);
            font-size: 0.98rem;
        }

        .login-form {
            margin-top: 28px;
            display: grid;
            gap: 18px;
        }

        .login-field {
            display: grid;
            gap: 8px;
        }

        .login-field label {
            font-weight: 500;
            color: var(--muted);
        }

        .login-field input {
            border-radius: 14px;
            border: 1px solid transparent;
            background: var(--card-strong);
            padding: 14px 16px;
            font-size: 1rem;
            color: var(--text);
            transition: border 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
        }

        .login-field input:focus {
            outline: none;
            border-color: rgba(124, 92, 255, 0.8);
            box-shadow: 0 0 0 4px rgba(124, 92, 255, 0.2);
            background: rgba(255, 255, 255, 0.18);
        }

        .login-button {
            border: none;
            border-radius: 14px;
            padding: 14px 18px;
            font-size: 1rem;
            font-weight: 600;
            color: #fff;
            background: linear-gradient(135deg, var(--accent), var(--accent-strong));
            cursor: pointer;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        .login-button:hover {
            transform: translateY(-1px);
            box-shadow: 0 12px 24px rgba(124, 92, 255, 0.35);
        }

        .login-meta {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 12px;
            font-size: 0.9rem;
            color: var(--muted);
        }

        .login-meta a {
            color: #d7d4ff;
            text-decoration: none;
        }

        .login-alert {
            background: rgba(255, 95, 109, 0.15);
            border: 1px solid rgba(255, 95, 109, 0.5);
            color: #ffd7dc;
            padding: 12px 16px;
            border-radius: 12px;
            font-size: 0.95rem;
        }

        .login-success {
            background: rgba(82, 255, 183, 0.16);
            border: 1px solid rgba(82, 255, 183, 0.4);
            color: #d6ffec;
            padding: 12px 16px;
            border-radius: 12px;
            font-size: 0.95rem;
        }
    </style>
{% endblock %}

{% block body %}
    <main class="login-shell">
        <section class="login-info">
            <h1>Bienvenue sur Archifoot.</h1>
            <p>Connectez-vous pour accéder à vos espaces d’analyse, gérer vos projets et retrouver vos données en toute sécurité.</p>
            <div class="info-pills">
                <span class="info-pill">Dashboard live</span>
                <span class="info-pill">Rapports en temps réel</span>
                <span class="info-pill">Support 24/7</span>
            </div>
        </section>

        <section class="login-card">
            <h2>Connexion</h2>
            <span>Ravi de vous revoir. Veuillez vous identifier.</span>

            <form method="post" class="login-form">
                {% if error %}
                    <div class="login-alert">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                {% endif %}

                {% if app.user %}
                    <div class="login-success">
                        Vous êtes connecté en tant que {{ app.user.userIdentifier }},
                        <a href="{{ logout_path() }}">Se déconnecter</a>
                    </div>
                {% endif %}

                <div class="login-field">
                    <label for="username">Email</label>
                    <input type="email" value="{{ last_username }}" name="_username" id="username" autocomplete="email" required autofocus>
                </div>

                <div class="login-field">
                    <label for="password">Mot de passe</label>
                    <input type="password" name="_password" id="password" autocomplete="current-password" required>
                </div>

                <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

                <div class="login-meta">
                    <span>Sécurité renforcée activée</span>
                    <a href="#">Mot de passe oublié ?</a>
                </div>

                <button class="login-button" type="submit">
                    Se connecter
                </button>
            </form>
        </section>
    </main>
{% endblock %}
