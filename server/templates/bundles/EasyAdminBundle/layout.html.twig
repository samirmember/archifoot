{% extends '@!EasyAdmin/layout.html.twig' %}

{% block header %}
    <header class="admin-shell__header">
        <div class="admin-shell__header-inner">
            <div class="admin-shell__brand">
                <span class="admin-shell__logo">AF</span>
                <div class="admin-shell__titles">
                    <span class="admin-shell__title">{{ ea.dashboardTitle ?? 'Archifoot Admin' }}</span>
                    <span class="admin-shell__subtitle">Console d'administration</span>
                </div>
            </div>
            <div class="admin-shell__actions">
                <div class="admin-shell__action">
                    <span class="admin-shell__label">Utilisateur</span>
                    <span class="admin-shell__value">
                        {% if app.user %}
                            {{ app.user.userIdentifier ?? app.user.email ?? 'Admin' }}
                        {% else %}
                            Invité
                        {% endif %}
                    </span>
                </div>
                <div class="admin-shell__action admin-shell__badge">
                    <span class="admin-shell__badge-dot"></span>
                    <span>Prêt à administrer</span>
                </div>
            </div>
        </div>
    </header>
{% endblock %}

{% block footer %}
    <footer class="admin-shell__footer">
        <div class="admin-shell__footer-inner">
            <div class="admin-shell__footer-brand">
                <strong>Archifoot</strong>
                <span class="admin-shell__footer-muted">Gestion moderne des données sportives.</span>
            </div>
            <div class="admin-shell__footer-links">
                <span>© {{ 'now'|date('Y') }}</span>
                <span class="admin-shell__footer-divider"></span>
                <span>Version interne</span>
            </div>
        </div>
    </footer>
{% endblock %}
